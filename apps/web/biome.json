{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": [".next", "dist", "build", "playwright-report", "test-results"]
  },
  "linter": {
    "enabled": true
  },
  "overrides": [
    {
      "include": ["src/app/globals.css"]
    },
    {
      "include": ["src/components/ui/label.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off"
          }
        }
      }
    }
  ]
}
