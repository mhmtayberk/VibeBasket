# ────────────────────────────────────────────────────────────────────────────
# VibeBasket — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# For Docker: DATABASE_URL=file:/data/vibebasket.db  (volume-mounted path)
# For manual install: use an absolute path on the host
DATABASE_URL=file:vibebasket.db

# ── Next-Auth ────────────────────────────────────────────────────────────────
# Required. Generate a random secret:  openssl rand -base64 32
AUTH_SECRET=

# Required. The public URL of your deployment (used for OAuth callback URLs)
NEXTAUTH_URL=http://localhost:3000

# ── GitHub OAuth (optional — enables GitHub login) ────────────────────────────
# Create an OAuth App at https://github.com/settings/applications/new
# Callback URL: ${NEXTAUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Admin access (optional) ───────────────────────────────────────────────────
# Comma-separated list of GitHub account emails that can access /admin
# Example: ADMIN_OAUTH_EMAILS=alice@example.com,bob@example.com
ADMIN_OAUTH_EMAILS=

# ── Reverse proxy (optional) ──────────────────────────────────────────────────
# Set to true when running behind Cloudflare, Nginx, Caddy, or any proxy
# that forwards the real client IP in X-Forwarded-For headers.
# Required for accurate rate limiting in production.
TRUST_PROXY=false
