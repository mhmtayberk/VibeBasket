# ────────────────────────────────────────────────────────────────────────────
# VibeBasket — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# For Docker: DATABASE_URL=file:/data/vibebasket.db  (volume-mounted path)
# For manual install: use an absolute path on the host
DATABASE_URL=file:vibebasket.db

# ── Next-Auth ────────────────────────────────────────────────────────────────
# Required. Generate a random secret:  openssl rand -base64 32
AUTH_SECRET=

# Required. The public URL of your deployment (used for OAuth callback URLs)
NEXTAUTH_URL=http://localhost:3000

# ── OAuth Providers (all optional — enable any subset) ───────────────────────
# Each provider requires AUTH_{PROVIDER}_ENABLED=true and its credentials.
# A provider is shown in the UI only when all its conditions are met.

# GitHub — https://github.com/settings/applications/new
# Callback: ${NEXTAUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ENABLED=false
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google — https://console.cloud.google.com/apis/credentials
# Callback: ${NEXTAUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ENABLED=false
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple — https://developer.apple.com/account/resources/identifiers
# Callback: ${NEXTAUTH_URL}/api/auth/callback/apple
AUTH_APPLE_ENABLED=false
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Microsoft Entra ID (Azure AD) — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Callback: ${NEXTAUTH_URL}/api/auth/callback/microsoft-entra-id
# Uses /common/ endpoint by default (personal + work/school accounts)
AUTH_MICROSOFT_ENTRA_ID_ENABLED=false
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# ── Admin access (optional) ───────────────────────────────────────────────────
# Comma-separated list of verified account emails that can access /admin
# Example: ADMIN_OAUTH_EMAILS=alice@example.com,bob@example.com
ADMIN_OAUTH_EMAILS=

# ── Reverse proxy (optional) ──────────────────────────────────────────────────
# Set to true when running behind Cloudflare, Nginx, Caddy, or any proxy
# that forwards the real client IP in X-Forwarded-For headers.
# Required for accurate rate limiting in production.
TRUST_PROXY=false

# Required for production OAuth when behind a reverse proxy.
# Set to true if your Next.js server receives forwarded host headers.
AUTH_TRUST_HOST=false

# ── Backup Storage (optional — defaults to local filesystem) ──────────────────
# Choose one backend: local (default), s3, r2, spaces, azure, gcs
# BACKUP_STORAGE_BACKEND=local

# Local backup directory (default: ./backups)
# BACKUP_LOCAL_DIR=/data/backups

# S3-compatible (AWS S3, Cloudflare R2, DigitalOcean Spaces)
# BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_BUCKET=vibebasket-backups
# BACKUP_S3_ACCESS_KEY=...
# BACKUP_S3_SECRET_KEY=...

# Cloudflare R2 (S3-compatible)
# BACKUP_R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# BACKUP_R2_BUCKET=vibebasket-backups
# BACKUP_R2_ACCESS_KEY=...
# BACKUP_R2_SECRET_KEY=...

# DigitalOcean Spaces (S3-compatible)
# BACKUP_SPACES_ENDPOINT=https://<region>.digitaloceanspaces.com
# BACKUP_SPACES_BUCKET=vibebasket-backups
# BACKUP_SPACES_ACCESS_KEY=...
# BACKUP_SPACES_SECRET_KEY=...

# Azure Blob Storage
# BACKUP_AZURE_CONNECTION_STRING=...
# BACKUP_AZURE_CONTAINER=vibebasket-backups

# Google Cloud Storage
# BACKUP_GCS_BUCKET=vibebasket-backups
# BACKUP_GCS_PROJECT_ID=my-project
