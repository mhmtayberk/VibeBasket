{
  "name": "@vibebasket/adapters",
  "version": "0.1.0",
  "description": "IDE adapters for VibeBasket",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "\"$npm_node_execpath\" ../../scripts/run-tsup.mjs",
    "test": "\"$npm_node_execpath\" ../../scripts/run-vitest.mjs run",
    "typecheck": "\"$npm_node_execpath\" ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@vibebasket/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "fast-check": "^4.9.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
