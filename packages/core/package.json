{
  "name": "@vibebasket/core",
  "version": "0.1.0",
  "description": "Core types, schemas and logic for VibeBasket",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest.ts",
    "./db": "./src/db/index.ts"
  },
  "scripts": {
    "build": "\"$npm_node_execpath\" ../../scripts/run-tsup.mjs",
    "test": "\"$npm_node_execpath\" ../../scripts/run-vitest.mjs run",
    "typecheck": "\"$npm_node_execpath\" ../../node_modules/typescript/bin/tsc -b"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.11",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
